{
  "app": {
    "name": "ConfigPilot",
    "defaultLanguage": "en",
    "languages": ["en", "hi"],
    "theme": {
      "primary": "#0f766e",
      "secondary": "#f97316"
    }
  },
  "auth": {
    "enabled": true,
    "methods": ["email_password", "magic_link_mock"]
  },
  "entities": [
    {
      "name": "projects",
      "label": "Projects",
      "fields": [
        { "name": "title", "type": "string", "required": true, "label": { "en": "Title", "hi": "Sheershak" } },
        { "name": "status", "type": "enum", "options": ["planned", "active", "done"], "required": true, "default": "planned", "label": { "en": "Status", "hi": "Sthiti" } },
        { "name": "budget", "type": "number", "required": false, "label": { "en": "Budget", "hi": "Bajat" } },
        { "name": "deadline", "type": "date", "required": false, "label": { "en": "Deadline", "hi": "Antim Tithi" } },
        { "name": "unknown_widget_data", "type": "mystery", "required": false }
      ],
      "ui": {
        "list": ["title", "status", "budget", "deadline"],
        "form": ["title", "status", "budget", "deadline", "unknown_widget_data"]
      }
    },
    {
      "name": "tasks",
      "label": "Tasks",
      "fields": [
        { "name": "name", "type": "string", "required": true, "label": { "en": "Task", "hi": "Karya" } },
        { "name": "project_id", "type": "number", "required": false, "label": { "en": "Project ID", "hi": "Project ID" } },
        { "name": "priority", "type": "enum", "options": ["low", "medium", "high"], "required": false, "default": "medium", "label": { "en": "Priority", "hi": "Prathmikta" } },
        { "name": "is_done", "type": "boolean", "required": false, "default": false, "label": { "en": "Done", "hi": "Poora" } }
      ],
      "ui": {
        "list": ["name", "priority", "is_done"],
        "form": ["name", "project_id", "priority", "is_done"]
      }
    }
  ]
}
